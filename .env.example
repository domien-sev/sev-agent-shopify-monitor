AGENT_NAME=shopify-monitor
AGENT_DESCRIPTION=Shopify translation monitor — daily scans for missing/bad NL→FR translations
AGENT_CAPABILITIES=shopify,translations,monitor,quality
AGENT_SLACK_CHANNEL=#agent-shopify-monitor
AGENT_ENDPOINT=http://agent-shopify-monitor:3000
AGENT_LLM_BACKEND=claude-code
AGENT_REPO_URL=https://github.com/domien-sev/sev-agent-shopify-monitor

DIRECTUS_URL=http://directus:8055
DIRECTUS_TOKEN=your-directus-static-token

SHOPIFY_SHOP=your-shop.myshopify.com
SHOPIFY_ACCESS_TOKEN=your-shopify-admin-api-token
DEEPL_API_KEY=your-deepl-api-key
DEEPL_FREE=false

ANTHROPIC_API_KEY=your-anthropic-api-key

SCAN_CRON=0 6 * * *
PORT=3000
